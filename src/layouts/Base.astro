---
// Base shell — shared <head>, theme stylesheet, font preloads. Pages
// render their content into the <slot/>. Intentionally minimal — the
// design language lives in components, not in this wrapper.
import "../styles/theme.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Quaestor — the audit office for the machine economy",
  description = "Local-first agent payments. Mandate JWTs, BLAKE3-chained ledger, on-device policy LLM.",
} = Astro.props;

const SITE_URL = "https://quaestor-site.vercel.app";
const OG_IMAGE = `${SITE_URL}/og-image.png`;
const OG_TITLE = "Quaestor";
const OG_DESCRIPTION =
  "The audit office for the machine economy. Non-custodial mandate engine for AI agent payments.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light only" />
    <meta name="description" content={description} />

    <meta property="og:title" content={OG_TITLE} />
    <meta property="og:description" content={OG_DESCRIPTION} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={OG_TITLE} />
    <meta name="twitter:description" content="The audit office for the machine economy." />
    <meta name="twitter:image" content={OG_IMAGE} />

    <link
      rel="preload"
      href="/fonts/cormorant-infant/cormorant-infant-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/jetbrains-mono/jetbrains-mono-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
